{
  "name": "@rusted-geom/bindings-web",
  "version": "0.1.0-alpha.2",
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "pack:local": "mkdir -p dist/wasm && cp ../../crates/kernel/pkg/rusted_geom_bg.wasm dist/wasm/rusted_geom.wasm && mkdir -p ../../dist/npm && npm pack --pack-destination ../../dist/npm"
  },
  "devDependencies": {
    "@types/node": "^24.4.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
