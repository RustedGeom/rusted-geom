<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <PackageId>RustedGeom.Bindings</PackageId>
    <Version>1.0.0</Version>
    <Authors>RustedGeom Contributors</Authors>
    <Description>Generated .NET bindings for the RustedGeom CAD kernel.</Description>
    <PackageTags>cad;geometry;nurbs;kernel;wasm</PackageTags>
    <RepositoryUrl>https://github.com/rusted-geom/rusted-geom</RepositoryUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
    <None Include="runtimes/**" Pack="true" PackagePath="runtimes/" />
  </ItemGroup>
</Project>
